# Database Encryption Password
# In Next.js, variables prefixed with NEXT_PUBLIC_ are available in the browser.
# For production, this MUST be a long, random string.
NEXT_PUBLIC_DB_PASSWORD=your-secure-password-here
# If unset, a random per-install key is generated and stored in the browser
# profile (localStorage). Explicitly setting a long random value here is
# recommended for production so the key survives browser-profile resets.
