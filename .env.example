# Database Encryption Password
# In Next.js, variables prefixed with NEXT_PUBLIC_ are available in the browser.
# For production, this MUST be a long, random string.
NEXT_PUBLIC_DB_PASSWORD=your-secure-password-here
# If unset, a random per-install key is generated and stored in the browser
# profile (localStorage). Explicitly setting a long random value here is
# recommended for production so the key survives browser-profile resets.

# ------------------------------------------------------------------
# 店舗内複数端末（サテライト端末同期）
# 単独端末で使う場合は設定不要（既定 standalone）。
# 手順: docs/satellite_terminal_sync_plan.md
# ------------------------------------------------------------------

# --- メイン端末（集約ハブ）の例 ---
# PHARMACY_SYNC_ROLE=hub
# ハブストア（患者データを含む正本SQLite）のat-rest暗号鍵。16進64文字（32バイト）。
# 例の値は使わず、`openssl rand -hex 32` などで生成すること。
# PHARMACY_SYNC_HUB_ENCRYPTION_KEY=<openssl rand -hex 32 で生成>
# PHARMACY_SYNC_HUB_DB_PATH=./data/sync_hub.sqlite

# --- サテライト端末の例 ---
# PHARMACY_SYNC_ROLE=satellite
# 接続先: 同一端末のlocalhostはHTTP可。施設内LANはHTTPS必須
# （HTTPしか使えないLANでは下のTRANSPORT暗号化を設定した場合のみ許可）。
# PHARMACY_SYNC_HUB_ENDPOINT=https://<メイン端末のホスト名かIP>:3000
# 端末IDとトークンはメイン端末の「設定 > 端末同期」で発行して転記する。
# PHARMACY_SYNC_TERMINAL_ID=satellite-1
# PHARMACY_SYNC_TERMINAL_TOKEN=<メイン端末で発行>
# LANがHTTPの場合のみ: 共有施設鍵でペイロードをAES-256-GCM暗号化する（hub側にも同じ設定が必要）。
# PHARMACY_SYNC_TRANSPORT_ENCRYPTION=aes-gcm
# PHARMACY_SYNC_TRANSPORT_KEY=<openssl rand -hex 32 で生成（全端末で同じ値）>
